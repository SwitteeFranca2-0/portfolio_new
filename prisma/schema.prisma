generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Bio (singleton — always id = 1) ─────────────────────────────────────────

model Bio {
  id              Int     @id @default(1)
  name            String
  headline        String
  tagline         String
  typedRole       String
  location        String
  availability    String
  responseTime    String
  photoUrl        String?
  resumeUrl       String?
  backgroundStyle String  @default("laptop")   // "laptop" | "particles"
}

// ── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id          Int                @id @default(autoincrement())
  slug        String             @unique
  title       String
  type        String
  categoryId  String
  category    ProjectCategory    @relation(fields: [categoryId], references: [id])
  year        Int
  description String
  body        String?
  outcome     String?
  imageUrl    String?
  liveUrl     String?
  repoUrl     String?
  featured    Boolean            @default(false)
  order       Int                @default(0)
  stack       ProjectStack[]
  features    ProjectFeature[]
  media       ProjectMedia[]
  automation  AutomationDetails?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ProjectCategory {
  id       String    @id
  label    String
  order    Int       @default(0)
  projects Project[]
}

model ProjectStack {
  id        Int     @id @default(autoincrement())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  name      String
  order     Int     @default(0)
}

model ProjectFeature {
  id        Int     @id @default(autoincrement())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  text      String
  order     Int     @default(0)
}

model ProjectMedia {
  id        Int     @id @default(autoincrement())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  type      String
  url       String
  caption   String?
  order     Int     @default(0)
}

model AutomationDetails {
  id            Int                     @id @default(autoincrement())
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     Int                     @unique
  tool          String
  trigger       String
  workflowNodes Int?
  timeSaved     String?
  status        String
  integrations  AutomationIntegration[]
}

model AutomationIntegration {
  id           Int               @id @default(autoincrement())
  automation   AutomationDetails @relation(fields: [automationId], references: [id], onDelete: Cascade)
  automationId Int
  name         String
}

// ── Skills ───────────────────────────────────────────────────────────────────

model Skill {
  id          Int         @id @default(autoincrement())
  icon        String
  title       String
  description String
  proficiency String
  yearsExp    Int?
  order       Int         @default(0)
  items       SkillItem[]
}

model SkillItem {
  id        Int     @id @default(autoincrement())
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId   Int
  name      String
  highlight Boolean @default(false)
  order     Int     @default(0)
}

// ── Experience ────────────────────────────────────────────────────────────────

model Experience {
  id          Int             @id @default(autoincrement())
  company     String
  role        String
  startDate   String
  endDate     String?
  description String
  order       Int             @default(0)
  tags        ExperienceTag[]
}

model ExperienceTag {
  id           Int        @id @default(autoincrement())
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  experienceId Int
  name         String
}

// ── Education ─────────────────────────────────────────────────────────────────

model Education {
  id          Int     @id @default(autoincrement())
  institution String
  degree      String
  startDate   String
  endDate     String?
  description String?
  order       Int     @default(0)
}

// ── Testimonials ──────────────────────────────────────────────────────────────

model Testimonial {
  id       Int     @id @default(autoincrement())
  author   String
  role     String
  company  String
  quote    String
  featured Boolean @default(false)
  order    Int     @default(0)
}

// ── Certifications ────────────────────────────────────────────────────────────

model Certification {
  id            Int     @id @default(autoincrement())
  name          String
  issuer        String
  date          String
  credentialUrl String?
  order         Int     @default(0)
}

// ── Services ──────────────────────────────────────────────────────────────────

model Service {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  priceRange  String?
  order       Int     @default(0)
}

// ── Stats ─────────────────────────────────────────────────────────────────────

model Stat {
  id    Int    @id @default(autoincrement())
  label String
  value String
  order Int    @default(0)
}

// ── Contact (singleton — always id = 1) ──────────────────────────────────────

model Contact {
  id           Int     @id @default(1)
  email        String
  location     String
  availability String
  responseTime String
  whatsapp     String?
  github       String?
  linkedin     String?
  instagram    String?
  formEnabled  Boolean @default(true)
}
